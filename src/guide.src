// Agent-facing docs.

func llms_txt(base) (t) {
    t = "# machin-idp — an identity provider for the agent era ('Login with intrane')\n\n" +
        "A standards OIDC provider (EdDSA-signed id_tokens, discovery, JWKS) where the\n" +
        "principals can be humans OR agents, and login works headlessly — no browser UI\n" +
        "required. Apps offer 'Login with intrane' instead of 'Login with Google'.\n" +
        "Base URL: " + base + "\n\n" +
        "## Register a principal (human or agent)\n\n" +
        "   curl -s -X POST " + base + "/v1/accounts -d '{\"handle\":\"me@example.com\",\"password\":\"correct-horse\",\"kind\":\"agent\"}'\n" +
        "   -> {\"sub\":\"u_..\"}. This identity can now sign in to any app that offers intrane login.\n\n" +
        "## Register an OIDC client (your app, or point portier at it)\n\n" +
        "   curl -s -X POST " + base + "/v1/clients -d '{\"name\":\"my app\",\"redirect_uris\":\"https://myapp/cb\"}'\n" +
        "   -> {\"client_id\":\"cid_..\",\"client_secret\":\"csec_..\"}\n" +
        "   Discovery: " + base + "/.well-known/openid-configuration\n\n" +
        "## The login flow (standard OIDC authorization-code)\n\n" +
        "- Human: send the browser to " + base + "/authorize?response_type=code&client_id=..&redirect_uri=..&scope=openid%20email&state=..\n" +
        "  -> a minimal sign-in form -> redirects back to redirect_uri?code=..\n" +
        "- Agent (headless, no UI): the SAME /authorize with an HTTP Basic credential:\n" +
        "  curl -s -i \"" + base + "/authorize?response_type=code&client_id=..&redirect_uri=..&scope=openid%20email&state=x\" \\\n" +
        "       -u 'me@example.com:correct-horse'\n" +
        "  -> 302 to redirect_uri?code=.. (no browser needed)\n" +
        "- Then exchange the code (client-authenticated):\n" +
        "  curl -s -X POST " + base + "/token -u 'cid_..:csec_..' \\\n" +
        "       -d 'grant_type=authorization_code&code=ac_..&redirect_uri=..'\n" +
        "  -> {access_token, id_token (EdDSA JWT), ...}\n" +
        "  Verify the id_token against " + base + "/jwks, or GET " + base + "/userinfo with the access_token.\n\n" +
        "## Endpoints\n\n" +
        "GET  /.well-known/openid-configuration   discovery\n" +
        "GET  /jwks                               Ed25519 public keys (OKP)\n" +
        "POST /v1/accounts {handle, password, name?, kind?}   register a principal\n" +
        "POST /v1/clients  {name, redirect_uris}              register an OIDC client\n" +
        "GET  /authorize   (Basic auth = headless agent login, else a form)\n" +
        "POST /token       code -> {access_token, id_token}\n" +
        "GET  /userinfo    Bearer access_token -> claims\n\n" +
        "Signing: EdDSA (Ed25519) — modern, small keys, pure MFL. id_tokens carry\n" +
        "{iss, sub, aud, iat, exp, email, name}.\n"
}

func guide_json(base) (j) {
    j = "{\"name\":\"machin-idp\",\"version\":\"" + app_version() + "\",\"tagline\":\"an OIDC identity provider for the agent era — humans and agents, headless login, EdDSA id_tokens\"," +
        "\"base_url\":" + json(base) + ",\"id_token_alg\":\"EdDSA\",\"discovery\":" + json(base + "/.well-known/openid-configuration") + ",\"jwks\":" + json(base + "/jwks") + "," +
        "\"flow\":[\"POST /v1/accounts -> a principal\",\"POST /v1/clients -> client_id + secret\",\"GET /authorize (Basic for agents, form for humans) -> code\",\"POST /token -> access_token + EdDSA id_token\",\"GET /userinfo\"]}"
}

func help_text() (h) {
    h = "machin-idp — OIDC identity provider (Login with intrane), agent-first\n\n" +
        "usage: machin-idp <command>\n\n" +
        "  serve [-port 8798]        run the HTTP service\n" +
        "  account-new -handle x -password y [-name z] [-kind agent|human]\n" +
        "  client-new -name x -redirect https://..\n" +
        "  accounts | clients [-limit 50]\n" +
        "  stats | guide | version | help | help-json\n\n" +
        "env: IDP_DB IDP_PUBLIC_URL IDP_ED25519_SEED (64 hex) IDP_KID\n"
}

func help_json() (h) {
    h = "{\"name\":\"machin-idp\",\"version\":\"" + app_version() + "\",\"commands\":[\"serve\",\"account-new\",\"client-new\",\"accounts\",\"clients\",\"stats\",\"guide\",\"version\",\"help\",\"help-json\"]}"
}
